{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "BILLMANAGER_DEVELOPMENT_BUILD": "true"
      },
      "ios": {
        "simulator": true
      }
    },
    "development:device": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "BILLMANAGER_DEVELOPMENT_BUILD": "true"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "BILLMANAGER_DEVELOPMENT_BUILD": "false"
      }
    },
    "preview:ios": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "BILLMANAGER_DEVELOPMENT_BUILD": "false"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "BILLMANAGER_DEVELOPMENT_BUILD": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
